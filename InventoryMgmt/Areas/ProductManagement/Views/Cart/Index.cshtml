@model List<Cart>

@{
ViewBag.Title = "Cart";
Layout = "_Layout";
}

<h2>Cart</h2>
<div id="alert-container" class="mt-3"></div>

@if (!Model.Any())
{
<p>There are no products in your cart. <a asp-controller="Product" asp-action="Index">See all products!</a></p>
}
else
{
<table class="table">
    <thead>
    <tr>
        <th>Product</th>
        <th>Price</th>
        <th>Quantity</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
    <tr id="row-@item.ProductId">
        <td>@item.ProductName</td>
        <td id="price-@item.ProductId">@item.Price.ToString("C")</td>
        <td>
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-sm btn-success btn-increment" data-id="@item.ProductId">+</button>
                <span id="quantity-@item.ProductId">@item.Quantity</span>
                <button class="btn btn-sm btn-warning btn-decrement" data-id="@item.ProductId">-</button>
            </div>
        </td>
        <td>
            <a asp-controller="Product" asp-action="View" asp-route-id="@item.ProductId" class="btn btn-primary btn-sm">View</a>
            <button class="btn btn-danger btn-sm btn-remove" data-id="@item.ProductId">Remove All</button>
        </td>
    </tr>
    }
    </tbody>
</table>

<h3>Total: <span id="cart-total">@Model.Sum(i => i.Price * i.Quantity).ToString("C")</span></h3>

<form asp-action="PlaceOrder" method="post" id="place-order-form">
    <div class="form-group">
        <label for="Name" class="form-label">Your name for this order:</label>
        <input type="text" id="Name" name="Name" class="form-control" required>
    </div>

    <br>
    <div class="form-group">
        <input type="submit" value="Place Order" class="btn btn-success">
        <a asp-controller="Product" asp-action="Index" class="btn btn-primary">Continue Shopping</a>
    </div>
</form>


}

@section Scripts {
    <script>
    function updateTotal() {
        let total = 0;
        $("tbody tr").each(function () {
            const id = $(this).attr("id").replace("row-", "");
            const price = parseFloat($("#price-" + id).text().replace(/[^0-9.-]+/g, ""));
            const quantity = parseInt($("#quantity-" + id).text());
            total += price * quantity;
        });
        $("#cart-total").text(total.toLocaleString("en-US", { style: "currency", currency: "USD" }));
    }

    function showSpinner() {
        $("#global-spinner").removeClass("d-none");
    }

    function hideSpinner() {
        $("#global-spinner").addClass("d-none");
    }

    function showAlert(message, type = "success") {
        const alertHtml = `
            <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>`;
        $("#alert-container").html(alertHtml);
    }

    $(".btn-increment").on("click", function () {
        const productId = $(this).data("id");
        showSpinner();
        setTimeout(() => {
            $.get(`/ProductManagement/Cart/AddToCart/${productId}`, function (data) {
                $("#quantity-" + productId).text(data.quantity);
                updateTotal();
                showAlert(data.message);
            }).always(hideSpinner);
        }, 1000);
    });

    $(".btn-decrement").on("click", function () {
        const productId = $(this).data("id");
        showSpinner();
        setTimeout(() => {
            $.get(`/ProductManagement/Cart/Decrement/${productId}`, function (data) {
                if (data.quantity > 0) {
                    $("#quantity-" + productId).text(data.quantity);
                } else {
                    $("#row-" + productId).remove();
                }
                updateTotal();
                showAlert(data.message);
            }).always(hideSpinner);
        }, 1000);
    });

    $(".btn-remove").on("click", function () {
        const productId = $(this).data("id");
        showSpinner();
        setTimeout(() => {
            $.get(`/ProductManagement/Cart/RemoveFromCart/${productId}`, function (data) {
                $("#row-" + productId).remove();
                updateTotal();
                showAlert(data.message);
            }).always(hideSpinner);
        }, 1000);
    });
</script>
<script>
    $("#place-order-form").on("submit", function (e) {
        e.preventDefault(); // prevent normal form submit

        $("#global-spinner").removeClass("d-none");

        const formData = $(this).serialize();

        setTimeout(() => {
            $.ajax({
                url: "/ProductManagement/Cart/PlaceOrder",
                method: "POST",
                data: formData,
                success: function () {
                    // Redirect after delay
                    setTimeout(() => {
                        window.location.href = "/ProductManagement/Order/MyOrders";
                    }, 1000);
                },
                error: function () {
                    window.location.href = "/Error/ServerError";
                }
            });
        }, 1000);
    });

</script>    
}


