@model List<Product>

@{
    ViewBag.Title = "All Products";
    Layout = "_Layout";
}

<h2>Products</h2>

@if (Model.Any())
{
    <div class="container">
        <div class="row">

            @foreach (var product in Model)
            {
            <div class="col-md-3 mb-2">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@product.ProductName</h5>
                        <p class="card-text">Category: @product.Category.Name</p>
                        <p class="card-text">Price: @product.Price.ToString("C")</p>
                        <p class="card-text">Stock: @product.Quantity</p>
                        <a href="#" class="btn btn-primary">View</a>
                        
                        @if (product.Quantity == 0)
                        {
                            <a href="#" class="btn btn-success disabled">Add to Order</a>
                        }
                        else
                        {
                            <a href="#" class="btn btn-success">Add to Order</a>
                        }
                    </div>
                </div>
            </div>
            }

        </div>
    </div>

}
else
{
    <p>There are currently no products to display. <a asp-action="Add">Add a Product</a></p>
}